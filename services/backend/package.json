{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "gen:openapi": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.3",
    "@ody/shared": "workspace:*",
    "@ody/types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/node": "^25.9.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "*",
    "vitest": "^2.1.8",
    "wrangler": "^3.101.0"
  }
}
